# PlaceOpt 환경변수 — 개발 환경 예시
# 실제 .env 파일에 복사 후 값 수정

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# JWT — 반드시 안전한 랜덤 값으로 교체
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://placeopt:placeopt_dev_pw@localhost:5432/placeopt_db
DATABASE_URL_SYNC=postgresql+psycopg2://placeopt:placeopt_dev_pw@localhost:5432/placeopt_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Service Account (Wave 2 예정 — Wave 1 공개 시트 CSV export 방식 사용)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./credentials/service_account.json

# CORS (콤마 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
