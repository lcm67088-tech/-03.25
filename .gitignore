# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Frontend build output (dist는 프론트엔드만 제외)
frontend/dist/

# Frontend dependencies
frontend/node_modules/

# pnpm store cache (로컬 전용)
.pnpm-store/

# 환경변수 정책:
#   .env, .env.local — 실제 시크릿 포함, 절대 커밋 금지
#   .env.staging, .env.production — 템플릿(플레이스홀더), 커밋 허용
#   .env.example — 예시, 커밋 허용
.env
.env.local
*.env.local
# frontend .env 파일: .env.development 는 민감정보 없으므로 허용
# backend .env 파일: 실제 secret 포함 가능하므로 .env.staging만 예외 허용
backend/.env
!backend/.env.staging
!backend/.env.example

# 가상환경
venv/
.venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo

# DB 로컬 파일
*.sqlite
*.db

# 자격증명 (절대 커밋 금지)
credentials/*.json
!credentials/.gitkeep

# Alembic
alembic/versions/__pycache__/

# 로그
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml
